---
---

<footer class="w-full border-t border-[var(--hairline)] bg-[var(--color-bg2)] py-12 text-[var(--color-ink-dim)]">
  <div class="mx-auto w-full max-w-6xl px-6 md:px-10">
    <div class="grid gap-10 md:grid-cols-4">
      <!-- Info -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <img
            src={`${import.meta.env.BASE_URL}favicon.svg`}
            alt="Minnie logo"
            width="24"
            height="24"
            class="h-6 w-6 rounded"
          />
          <span class="font-[family-name:var(--font-display)] text-lg font-semibold tracking-tight text-[var(--color-ink)]">
            Minnie
          </span>
        </div>
        <p class="text-sm max-w-sm mb-4 leading-relaxed">
          Minnie is a native macOS companion that brings your AI coding agent to life. She listens, runs your agent, asks permission, and reacts.
        </p>
        <span class="text-xs text-[var(--color-lilac-muted)]">
          🔒 On-device voice · runs on your Mac · local-only positioning
        </span>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-sm font-bold text-[var(--color-ink)] mb-4 uppercase tracking-wider">Product</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="#features" class="hover:text-[var(--color-coral)] transition-colors">Features</a></li>
          <li><a href="#customize" class="hover:text-[var(--color-coral)] transition-colors">Customize</a></li>
          <li><a href="#mcp" class="hover:text-[var(--color-coral)] transition-colors">MCP Catalog</a></li>
          <li><a href="#pricing" class="hover:text-[var(--color-coral)] transition-colors">Pricing</a></li>
        </ul>
      </div>

      <!-- Community/Socials -->
      <div>
        <h4 class="text-sm font-bold text-[var(--color-ink)] mb-4 uppercase tracking-wider">Connect</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="https://x.com/Sym6ol_" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-coral)] transition-colors">X (Twitter)</a></li>
          <li><a href="https://github.com/Pratik-Singh-web/Minnie" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-coral)] transition-colors">GitHub</a></li>
          <li><a href="#faq" class="hover:text-[var(--color-coral)] transition-colors">FAQ</a></li>
          <li><a href="mailto:pratiksingh30701@gmail.com" class="hover:text-[var(--color-coral)] transition-colors">Send Feedback</a></li>
        </ul>
      </div>
    </div>

    <!-- Divider -->
    <div class="mt-12 pt-8 border-t border-[var(--hairline)] flex flex-col md:flex-row items-center justify-between gap-4 text-xs">
      <div class="flex items-center gap-4">
        <span>&copy; {new Date().getFullYear()} Minnie. All rights reserved.</span>
        <a href={`${import.meta.env.BASE_URL}privacy`} class="hover:text-[var(--color-coral)] transition-colors">Privacy Policy</a>
      </div>
      <div class="flex items-center gap-1">
        <span>Made with love by an indie developer.</span>
        <span class="text-[var(--color-coral)]">Deny is a hug, not a scold.</span>
      </div>
    </div>
  </div>
</footer>
