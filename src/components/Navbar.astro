---
---

<header class="sticky top-0 z-50 w-full border-b border-[var(--hairline)] bg-opacity-70 bg-[var(--color-bg0)] backdrop-blur-md">
  <div class="mx-auto flex h-16 w-full max-w-6xl items-center justify-between px-6 md:px-10">
    <!-- Logo -->
    <a href="#" class="flex items-center gap-2">
      <img
        src={`${import.meta.env.BASE_URL}favicon.svg`}
        alt="Minnie logo"
        width="32"
        height="32"
        class="h-8 w-8 rounded-lg shadow-md shadow-pink-500/20"
      />
      <span class="font-[family-name:var(--font-display)] text-xl font-semibold tracking-tight text-[var(--color-ink)]">
        Minnie
      </span>
      <span class="rounded-full bg-pink-500/10 px-2 py-0.5 text-[10px] font-bold text-[var(--color-coral)]">
        ACTIVE
      </span>
    </a>

    <!-- Navigation -->
    <nav class="hidden md:flex items-center gap-8 text-sm font-semibold text-[var(--color-ink-dim)]">
      <a href="#features" class="hover:text-[var(--color-coral-hover)] transition-colors">Features</a>
      <a href="#demo" class="hover:text-[var(--color-coral-hover)] transition-colors">How it works</a>
      <a href="#customize" class="hover:text-[var(--color-coral-hover)] transition-colors">Customize</a>
      <a href="#mcp" class="hover:text-[var(--color-coral-hover)] transition-colors">MCP</a>
      <a href="#pricing" class="hover:text-[var(--color-coral-hover)] transition-colors">Pricing</a>
      <a href="#faq" class="hover:text-[var(--color-coral-hover)] transition-colors">FAQ</a>
    </nav>

    <!-- CTA -->
    <div class="flex items-center gap-4">
      <a href="#waitlist" class="btn-primary py-2 px-5 text-sm shadow-none hover:shadow-lg">
        Join Waitlist
      </a>
    </div>
  </div>
</header>
