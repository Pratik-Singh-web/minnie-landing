---
---

<header class="sticky top-0 z-50 w-full border-b border-[var(--hairline)] bg-opacity-70 bg-[var(--color-bg0)] backdrop-blur-md">
  <div class="mx-auto flex h-16 w-full max-w-6xl items-center justify-between px-6 md:px-10">
    <!-- Logo -->
    <a href="#" class="flex items-center gap-2">
      <img
        src={`${import.meta.env.BASE_URL}favicon.svg`}
        alt="Minnie logo"
        width="32"
        height="32"
        class="h-8 w-8 rounded-lg shadow-md shadow-pink-500/20"
      />
      <span class="font-[family-name:var(--font-display)] text-xl font-semibold tracking-tight text-[var(--color-ink)]">
        Minnie
      </span>
      <span class="rounded-full bg-pink-500/10 px-2 py-0.5 text-[10px] font-bold text-[var(--color-coral)]">
        ACTIVE
      </span>
    </a>

    <!-- Navigation -->
    <nav class="hidden md:flex items-center gap-8 text-sm font-semibold text-[var(--color-ink-dim)]">
      <a href="#features" class="hover:text-[var(--color-coral-hover)] transition-colors">Features</a>
      <a href="#demo" class="hover:text-[var(--color-coral-hover)] transition-colors">How it works</a>
      <a href="#customize" class="hover:text-[var(--color-coral-hover)] transition-colors">Customize</a>
      <a href="#mcp" class="hover:text-[var(--color-coral-hover)] transition-colors">MCP</a>
      <a href="#pricing" class="hover:text-[var(--color-coral-hover)] transition-colors">Pricing</a>
      <a href="#faq" class="hover:text-[var(--color-coral-hover)] transition-colors">FAQ</a>
    </nav>

    <!-- CTA -->
    <div class="flex items-center gap-3">
      <button
        id="theme-toggle"
        type="button"
        class="clay-icon-btn"
        aria-label="Toggle light and dark theme"
        title="Toggle theme"
      >
        <svg class="theme-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        <svg class="theme-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
      </button>
      <a href="#waitlist" class="btn-primary py-2 px-5 text-sm">
        Join Waitlist
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("theme-toggle");
  btn?.addEventListener("click", () => {
    const cur = document.documentElement.getAttribute("data-theme") === "light" ? "light" : "dark";
    const next = cur === "light" ? "dark" : "light";
    document.documentElement.setAttribute("data-theme", next);
    try { localStorage.setItem("theme", next); } catch (e) {}
  });
</script>
