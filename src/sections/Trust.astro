---
---

<section class="py-16 md:py-24 border-b border-[var(--hairline)]">
  <div class="mx-auto max-w-6xl px-6 md:px-10 grid gap-12 md:grid-cols-12 items-center">
    
    <!-- Left: Trust Visual Card (5 cols) -->
    <div class="md:col-span-5 relative flex justify-center">
      <!-- Ambient Glow background -->
      <div class="absolute w-60 h-60 rounded-full bg-[var(--color-periwinkle)] opacity-10 blur-3xl -z-10"></div>

      <!-- Trust Visual Container -->
      <div class="card p-8 w-full max-w-sm border-white/5 relative overflow-hidden flex flex-col items-center">
        <!-- Interactive Cloud bubble -->
        <div class="w-full bg-gradient-to-b from-white to-[#ffe3ee] rounded-2xl p-5 shadow-lg relative mb-6">
          <div class="absolute -bottom-2 right-24 w-4 h-4 bg-[#ffe3ee] transform rotate-45 z-0"></div>
          
          <div class="flex items-center gap-2 mb-2 text-xs text-[var(--color-lilac-muted)] font-mono">
            <span>🔧 Edit</span>
            <span>mock_users.py</span>
          </div>
          
          <p class="text-sm font-semibold text-[var(--color-ink-onlight)] mb-4">
            I want to append the mock authentication payload. Ok?
          </p>

          <!-- Cloud Options -->
          <div class="flex gap-2">
            <button class="flex-1 py-1.5 px-3 rounded-full text-xs font-semibold border border-red-200 text-[var(--color-danger)] hover:bg-red-50 transition-colors cursor-pointer text-center">
              Deny
            </button>
            <button class="flex-1 py-1.5 px-3 rounded-full text-xs font-semibold bg-[var(--color-mint)] text-white hover:bg-opacity-95 transition-colors cursor-pointer text-center">
              Allow once
            </button>
          </div>
        </div>

        <!-- 3D Mascot Image (thinking) -->
        <div class="w-28 h-28 flex items-center justify-center">
          <img
            src="/media/thinking.png"
            alt="Minnie verifying permissions"
            class="max-w-full max-h-full object-contain filter drop-shadow-md"
          />
        </div>
      </div>
    </div>

    <!-- Right: Trust Copy (7 cols) -->
    <div class="md:col-span-7 text-left">
      <span class="eyebrow">Consent Trust Layer</span>
      <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-5xl font-bold mt-2 text-[var(--color-ink)] leading-tight">
        Deny is a hug, not a scold.
      </h2>
      <p class="text-[var(--color-ink-dim)] mt-4 leading-relaxed">
        Every terminal command, every file edit, and every workspace read is gated by a consent screen. If you say no, she steps back immediately. No broken terminal sessions, no corrupted configurations, and no unexpected changes.
      </p>

      <!-- Bullets -->
      <div class="grid gap-4 mt-8 sm:grid-cols-2">
        <div class="flex gap-3">
          <div class="text-[var(--color-coral)] font-bold text-lg">✓</div>
          <div>
            <h4 class="font-bold text-white text-sm">Allow once</h4>
            <p class="text-xs text-[var(--color-ink-dim)] mt-1">Approve only the immediate next action.</p>
          </div>
        </div>

        <div class="flex gap-3">
          <div class="text-[var(--color-periwinkle)] font-bold text-lg">✓</div>
          <div>
            <h4 class="font-bold text-white text-sm">For session</h4>
            <p class="text-xs text-[var(--color-ink-dim)] mt-1">Auto-approve safe reads for the next hour.</p>
          </div>
        </div>

        <div class="flex gap-3">
          <div class="text-[var(--color-mint)] font-bold text-lg">✓</div>
          <div>
            <h4 class="font-bold text-white text-sm">Default mode</h4>
            <p class="text-xs text-[var(--color-ink-dim)] mt-1">Interactive review of edits + command approvals.</p>
          </div>
        </div>

        <div class="flex gap-3">
          <div class="text-[var(--color-amber)] font-bold text-lg">✓</div>
          <div>
            <h4 class="font-bold text-white text-sm">Plan mode</h4>
            <p class="text-xs text-[var(--color-ink-dim)] mt-1">Research and draft suggestions without modifications.</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
