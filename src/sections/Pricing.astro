---
---

<section id="pricing" class="py-16 md:py-24 bg-[var(--color-bg1)] border-b border-[var(--hairline)]">
  <div class="mx-auto max-w-6xl px-6 md:px-10">
    
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-12">
      <span class="eyebrow">Pricing</span>
      <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-5xl font-bold mt-2 text-[var(--color-ink)]">
        One-time purchase, yours forever
      </h2>
      <p class="text-[var(--color-ink-dim)] mt-4 leading-relaxed">
        No monthly bills, no recurring subscriptions, and zero extra markup fees on your AI usage.
      </p>
    </div>

    <!-- Pricing Card -->
    <div class="max-w-md mx-auto">
      <div class="card p-8 border-[var(--color-coral)] shadow-2xl relative overflow-hidden bg-gradient-to-b from-pink-500/[0.02] to-transparent">
        
        <!-- Founder Badge -->
        <div class="absolute top-4 right-4">
          <span class="chip border-pink-500/30 bg-pink-500/10 text-[var(--color-coral)] font-bold text-[10px] tracking-widest uppercase">
            Founder Offer
          </span>
        </div>

        <h3 class="font-[family-name:var(--font-display)] text-2xl font-bold text-[var(--color-ink)] mb-2">
          Minnie License
        </h3>
        <p class="text-xs text-[var(--color-lilac-muted)] mb-6">
          Limited to the first 500 developers.
        </p>

        <!-- Pricing Numbers -->
        <div class="flex items-baseline gap-2 mb-6">
          <span class="text-5xl font-extrabold text-[var(--color-ink)] font-[family-name:var(--font-display)]">$9</span>
          <span class="text-sm text-[var(--color-ink-dim)] line-through">$19</span>
          <span class="text-xs text-[var(--color-lilac-muted)] font-semibold uppercase tracking-wider ml-1">
            one-time fee
          </span>
        </div>

        <!-- Features list -->
        <ul class="space-y-4 mb-8 text-sm text-[var(--color-ink-dim)]">
          <li class="flex items-center gap-3">
            <span class="text-[var(--color-mint)]">✓</span>
            <span>Bring Your Own Agent (No AI cost)</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="text-[var(--color-mint)]">✓</span>
            <span>macOS App DMG (Windows coming)</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="text-[var(--color-mint)]">✓</span>
            <span>Lifetime license & free updates in v1</span>
          </li>
          <li class="flex items-center gap-3">
            <span class="text-[var(--color-mint)]">✓</span>
            <span>Local speech synthesis & key storage</span>
          </li>
        </ul>

        <!-- Action CTA -->
        <a href="#waitlist" class="btn-primary w-full justify-center text-sm py-4">
          Lock in Founder Price →
        </a>

        <p class="text-center text-[10px] text-[var(--color-lilac-muted)] mt-4">
          🛡️ 30-day money-back guarantee post-launch.
        </p>

      </div>
    </div>

  </div>
</section>
