---
---

<section id="mcp" class="py-16 md:py-24 bg-[var(--color-bg1)] border-b border-[var(--hairline)]">
  <div class="mx-auto max-w-6xl px-6 md:px-10">
    
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="eyebrow">Integrations</span>
      <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-5xl font-bold mt-2 text-[var(--color-ink)]">
        Connect all your developer tools
      </h2>
      <p class="text-[var(--color-ink-dim)] mt-4 leading-relaxed">
        Connect GitHub, Notion, Slack, and your databases over Model Context Protocol (MCP) — or Sign in with Google for native Workspace support.
      </p>
    </div>

    <!-- Integrations Grid -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      
      <!-- GitHub -->
      <div class="card p-6 flex flex-col justify-between hover:border-white/20 transition-all duration-300 group">
        <div>
          <div class="flex items-center justify-between mb-4">
            <span class="text-3xl">🐙</span>
            <span class="chip py-0.5 px-2 text-[9px] bg-white/5 border-none">MCP SDK</span>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">GitHub</h3>
          <p class="text-xs text-[var(--color-ink-dim)] leading-relaxed">
            Verify active pull requests, create issues, search repositories, and sync code branches directly through voice commands.
          </p>
        </div>
        <div class="mt-6 pt-4 border-t border-white/5 text-[10px] text-[var(--color-lilac-muted)] group-hover:text-[var(--color-coral)] transition-colors">
          Connected via GitHub MCP Server
        </div>
      </div>

      <!-- Notion -->
      <div class="card p-6 flex flex-col justify-between hover:border-white/20 transition-all duration-300 group">
        <div>
          <div class="flex items-center justify-between mb-4">
            <span class="text-3xl">📝</span>
            <span class="chip py-0.5 px-2 text-[9px] bg-white/5 border-none">MCP SDK</span>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Notion</h3>
          <p class="text-xs text-[var(--color-ink-dim)] leading-relaxed">
            Read project specifications, write design documents, and append technical notes to your team's knowledge workspace.
          </p>
        </div>
        <div class="mt-6 pt-4 border-t border-white/5 text-[10px] text-[var(--color-lilac-muted)] group-hover:text-[var(--color-coral)] transition-colors">
          Connected via Notion MCP Server
        </div>
      </div>

      <!-- Slack -->
      <div class="card p-6 flex flex-col justify-between hover:border-white/20 transition-all duration-300 group">
        <div>
          <div class="flex items-center justify-between mb-4">
            <span class="text-3xl">💬</span>
            <span class="chip py-0.5 px-2 text-[9px] bg-white/5 border-none">MCP SDK</span>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Slack</h3>
          <p class="text-xs text-[var(--color-ink-dim)] leading-relaxed">
            Send success alerts to your deployment channel or fetch message history from teammates without switching applications.
          </p>
        </div>
        <div class="mt-6 pt-4 border-t border-white/5 text-[10px] text-[var(--color-lilac-muted)] group-hover:text-[var(--color-coral)] transition-colors">
          Connected via Slack MCP Server
        </div>
      </div>

      <!-- Postgres -->
      <div class="card p-6 flex flex-col justify-between hover:border-white/20 transition-all duration-300 group">
        <div>
          <div class="flex items-center justify-between mb-4">
            <span class="text-3xl">🗄️</span>
            <span class="chip py-0.5 px-2 text-[9px] bg-white/5 border-none">MCP Database</span>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Postgres & MySQL</h3>
          <p class="text-xs text-[var(--color-ink-dim)] leading-relaxed">
            Verify table structures, run safe local migrations, and validate mock data values when writing backend integrations.
          </p>
        </div>
        <div class="mt-6 pt-4 border-t border-white/5 text-[10px] text-[var(--color-lilac-muted)] group-hover:text-[var(--color-coral)] transition-colors">
          Connected via Database MCP Server
        </div>
      </div>

      <!-- Google Workspace -->
      <div class="card p-6 flex flex-col justify-between hover:border-white/20 transition-all duration-300 group">
        <div>
          <div class="flex items-center justify-between mb-4">
            <span class="text-3xl">📧</span>
            <span class="chip py-0.5 px-2 text-[9px] border-none bg-pink-500/10 text-[var(--color-coral)]">Google OAuth</span>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Google Workspace</h3>
          <p class="text-xs text-[var(--color-ink-dim)] leading-relaxed">
            Sync email digests, fetch calendar schedules, and check chat updates. Native Sign-in with Google keeps setup simple.
          </p>
        </div>
        <div class="mt-6 pt-4 border-t border-white/5 text-[10px] text-[var(--color-lilac-muted)] group-hover:text-[var(--color-coral)] transition-colors">
          Connected via Google OAuth Credentials
        </div>
      </div>

      <!-- Custom Server -->
      <div class="card p-6 flex flex-col justify-between hover:border-white/20 transition-all duration-300 group">
        <div>
          <div class="flex items-center justify-between mb-4">
            <span class="text-3xl">🛠️</span>
            <span class="chip py-0.5 px-2 text-[9px] bg-white/5 border-none">Local / Custom</span>
          </div>
          <h3 class="text-lg font-bold text-white mb-2">Custom MCP Tools</h3>
          <p class="text-xs text-[var(--color-ink-dim)] leading-relaxed">
            Connect any local scripts or private MCP tool servers by adding their startup definitions to your local configuration.
          </p>
        </div>
        <div class="mt-6 pt-4 border-t border-white/5 text-[10px] text-[var(--color-lilac-muted)] group-hover:text-[var(--color-coral)] transition-colors">
          Add it once in Minnie's Connections panel
        </div>
      </div>

    </div>

  </div>
</section>
