---
---

<section id="features" class="py-16 md:py-24 border-t border-[var(--hairline)]">
  <div class="mx-auto max-w-6xl px-6 md:px-10">
    
    <!-- Section Heading -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="eyebrow">The Minnie Difference</span>
      <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-5xl font-bold mt-2 text-[var(--color-ink)]">
        Chatbots talk. Minnie executes.
      </h2>
      <p class="text-[var(--color-ink-dim)] mt-4 leading-relaxed">
        Sits on top of the AI coding agents you already pay for to add a body, local voice command, and real-time consent feedback.
      </p>
    </div>

    <!-- 3 Core Benefits Grid -->
    <div class="grid gap-8 md:grid-cols-3 mb-20">
      
      <!-- Benefit 1 -->
      <div class="card p-8 flex flex-col justify-between hover:border-[var(--color-coral)] transition-colors duration-300">
        <div>
          <!-- Icon -->
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-pink-500/20 to-orange-500/20 flex items-center justify-center mb-6 text-2xl text-[var(--color-coral)]">
            ⚡
          </div>
          <h3 class="font-[family-name:var(--font-display)] text-xl font-bold text-[var(--color-ink)] mb-3">
            Executes, doesn't just chat
          </h3>
          <p class="text-sm text-[var(--color-ink-dim)] leading-relaxed">
            Minnie drives your CLI agent to build real files, run shell commands, perform research, and solve errors. A browser chatbot just talks; Minnie does.
          </p>
        </div>
        <div class="mt-6 pt-4 border-t border-[var(--clay-edge)] flex gap-2">
          <span class="chip">Writes code</span>
          <span class="chip">Runs tests</span>
        </div>
      </div>

      <!-- Benefit 2 -->
      <div class="card p-8 flex flex-col justify-between hover:border-[var(--color-periwinkle)] transition-colors duration-300">
        <div>
          <!-- Icon -->
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-purple-500/20 to-blue-500/20 flex items-center justify-center mb-6 text-2xl text-[var(--color-periwinkle)]">
            🗣️
          </div>
          <h3 class="font-[family-name:var(--font-display)] text-xl font-bold text-[var(--color-ink)] mb-3">
            Asks permission aloud
          </h3>
          <p class="text-sm text-[var(--color-ink-dim)] leading-relaxed">
            Before executing a command or writing a file, Minnie speaks the action: <em>"I want to run pytest. Ok?"</em>. Reply with your voice to allow, deny, or automate.
          </p>
        </div>
        <div class="mt-6 pt-4 border-t border-[var(--clay-edge)] flex gap-2">
          <span class="chip">Voice consent</span>
          <span class="chip">You're in control</span>
        </div>
      </div>

      <!-- Benefit 3 -->
      <div class="card p-8 flex flex-col justify-between hover:border-[var(--color-mint)] transition-colors duration-300">
        <div>
          <!-- Icon -->
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-emerald-500/20 to-teal-500/20 flex items-center justify-center mb-6 text-2xl text-[var(--color-mint)]">
            🔒
          </div>
          <h3 class="font-[family-name:var(--font-display)] text-xl font-bold text-[var(--color-ink)] mb-3">
            Local, private, secure
          </h3>
          <p class="text-sm text-[var(--color-ink-dim)] leading-relaxed">
            Fully on-device Apple voice synthesis, a local agent CLI interface, and zero third-party telemetry. Your private codebase, secrets, and auth remain safe on your Mac.
          </p>
        </div>
        <div class="mt-6 pt-4 border-t border-[var(--clay-edge)] flex gap-2">
          <span class="chip">Zero cloud logs</span>
          <span class="chip">Keychain auth</span>
        </div>
      </div>

    </div>

    <!-- Works with your Agent Strip -->
    <div class="card p-6 flex flex-col md:flex-row items-center justify-between gap-6 border-[var(--clay-edge)] bg-gradient-to-r from-white/[0.02] to-transparent">
      <div class="max-w-md">
        <h4 class="font-bold text-[var(--color-ink)] text-sm uppercase tracking-wider mb-1">
          Bring your own agent + skills
        </h4>
        <p class="text-xs text-[var(--color-ink-dim)]">
          Minnie sits on top of your existing CLI agent. Zero switching cost, and zero extra AI usage fees.
        </p>
      </div>

      <!-- Agent Badges -->
      <div class="flex flex-wrap items-center gap-2">
        <span class="chip border-pink-500/20 bg-pink-500/5 text-[var(--color-coral)] font-bold">
          Claude Code (Full)
        </span>
        <span class="chip">
          Gemini CLI
        </span>
        <span class="chip">
          Codex
        </span>
        <span class="chip">
          Custom Agents
        </span>
      </div>
    </div>

  </div>
</section>
