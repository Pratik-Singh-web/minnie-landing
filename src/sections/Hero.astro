---
import WaitlistForm from "../components/WaitlistForm.astro";
---

<section class="relative overflow-hidden pt-20 pb-16 md:pt-32 md:pb-24">
  <div class="mx-auto max-w-6xl px-6 md:px-10 grid gap-12 lg:grid-cols-12 items-center">
    <!-- Hero Text -->
    <div class="lg:col-span-7 flex flex-col items-start text-left z-10">
      <div class="mb-4">
        <span class="eyebrow inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-[var(--hairline)]">
          <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-coral)] animate-pulse"></span>
          NATIVE macOS · YOUR AGENT, WITH A BODY
        </span>
      </div>

      <h1 class="font-[family-name:var(--font-display)] text-5xl font-bold leading-[0.95] tracking-tight text-[var(--color-ink)] md:text-7xl">
        Give your AI agent<br />
        a <span class="bg-gradient-to-r from-[var(--color-coral)] to-[var(--color-peach)] bg-clip-text text-transparent">body.</span>
      </h1>

      <p class="mt-6 max-w-xl text-lg md:text-xl text-[var(--color-ink-dim)] leading-relaxed">
        A native macOS desktop pet that runs the AI coding agent you already use — talk to it, and watch it work. Zero extra AI cost. Fully private.
      </p>

      <!-- Waitlist Form Section -->
      <div id="waitlist" class="mt-8">
        <WaitlistForm size="lg" />
      </div>

      <!-- Privacy Badges -->
      <div class="mt-8 flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-[var(--color-ink-softcoral)] font-semibold">
        <span class="flex items-center gap-1">🔒 On-device voice</span>
        <span class="text-[var(--color-lilac-muted)]">•</span>
        <span class="flex items-center gap-1">💻 Runs on your Mac</span>
        <span class="text-[var(--color-lilac-muted)]">•</span>
        <span class="flex items-center gap-1">🛠️ BYO Agent (Zero Extra Cost)</span>
      </div>
    </div>

    <!-- Hero Visual / Floating Pet Mockup -->
    <div class="lg:col-span-5 relative flex justify-center items-center">
      <!-- Glow background -->
      <div class="absolute w-72 h-72 rounded-full bg-[var(--color-coral)] opacity-20 blur-3xl -z-10"></div>
      
      <!-- Interactive Frame / macOS mockup container -->
      <div class="card w-full max-w-sm aspect-[4/3] p-8 flex flex-col justify-between shadow-2xl border-[var(--clay-edge)] relative overflow-hidden group">
        <!-- Window Controls -->
        <div class="flex items-center gap-1.5 absolute top-4 left-4">
          <div class="w-2.5 h-2.5 rounded-full bg-red-500/80"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/80"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-green-500/80"></div>
        </div>

        <div class="absolute top-4 right-4 flex gap-1">
          <span class="chip py-0.5 px-2 text-[9px] border-none bg-[var(--clay-inset)]">Minnie.app</span>
        </div>

        <!-- Center Image content with mood hover interaction -->
        <div class="flex-1 flex flex-col items-center justify-center mt-6">
          <div class="relative w-40 h-40 flex items-center justify-center transition-all duration-300 transform group-hover:scale-105">
            <!-- Idle Pet -->
            <img
              src={`${import.meta.env.BASE_URL}media/idle.png`}
              alt="Minnie Mascot"
              id="hero-pet-img"
              class="max-w-full max-h-full object-contain filter drop-shadow-[0_10px_20px_rgba(255,107,157,0.3)] transition-all duration-300"
            />
            <!-- Ambient Speach/waveform representation -->
            <div class="absolute bottom-[-10px] left-1/2 transform -translate-x-1/2 flex items-center gap-1 bg-[var(--terminal-bg)] px-3 py-1 rounded-full border border-[var(--clay-edge)] backdrop-blur">
              <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-mint)]"></span>
              <span class="text-[9px] font-mono text-[var(--color-ink-dim)]">Status: Idle</span>
            </div>
          </div>
        </div>

        <!-- Interactive trigger helper -->
        <div class="text-center mt-2">
          <p class="text-xs text-[var(--color-lilac-muted)] italic">
            Hover over the card to see her sit up!
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Hover Pet Interaction (Change image to thinking when hovering)
  const heroCard = document.querySelector('.group');
  const heroPet = document.getElementById('hero-pet-img') as HTMLImageElement;
  if (heroCard && heroPet) {
    heroCard.addEventListener('mouseenter', () => {
      heroPet.src = import.meta.env.BASE_URL + 'media/thinking.png';
    });
    heroCard.addEventListener('mouseleave', () => {
      heroPet.src = import.meta.env.BASE_URL + 'media/idle.png';
    });
  }
</script>
