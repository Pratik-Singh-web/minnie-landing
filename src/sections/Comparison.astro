---
---

<section class="py-16 md:py-24 border-b border-[var(--hairline)]">
  <div class="mx-auto max-w-6xl px-6 md:px-10">
    
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="eyebrow">Comparison</span>
      <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-5xl font-bold mt-2 text-[var(--color-ink)]">
        Why Minnie?
      </h2>
      <p class="text-[var(--color-ink-dim)] mt-4 leading-relaxed">
        How Minnie compares to browser-based chatbots and standard command-line tools.
      </p>
    </div>

    <!-- Comparison Table Card -->
    <div class="card overflow-hidden border-[var(--clay-edge)] shadow-2xl">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="border-b border-[var(--hairline)] bg-[var(--clay-inset)]">
              <th class="p-6 text-sm font-bold text-[var(--color-ink)]">Capability</th>
              <th class="p-6 text-sm font-bold text-[var(--color-coral)] bg-pink-500/5">Minnie Pet</th>
              <th class="p-6 text-sm font-bold text-[var(--color-lilac-muted)]">Web Chatbot</th>
              <th class="p-6 text-sm font-bold text-[var(--color-lilac-muted)]">Standard CLI Agent</th>
            </tr>
          </thead>
          <tbody class="text-sm divide-y divide-[var(--clay-edge)]">
            
            <!-- Row 1 -->
            <tr class="hover:bg-[var(--clay-inset)] transition-colors">
              <td class="p-6 font-semibold text-[var(--color-ink)]">Executes tasks locally on your Mac</td>
              <td class="p-6 text-[var(--color-mint)] font-bold bg-pink-500/5">✓ Yes</td>
              <td class="p-6 text-[var(--color-danger)] font-bold">✗ No</td>
              <td class="p-6 text-[var(--color-mint)] font-bold">✓ Yes</td>
            </tr>

            <!-- Row 2 -->
            <tr class="hover:bg-[var(--clay-inset)] transition-colors">
              <td class="p-6 font-semibold text-[var(--color-ink)]">Voice command + consent cloud</td>
              <td class="p-6 text-[var(--color-mint)] font-bold bg-pink-500/5">✓ Yes</td>
              <td class="p-6 text-[var(--color-danger)] font-bold">✗ No</td>
              <td class="p-6 text-[var(--color-danger)] font-bold">✗ No</td>
            </tr>

            <!-- Row 3 -->
            <tr class="hover:bg-[var(--clay-inset)] transition-colors">
              <td class="p-6 font-semibold text-[var(--color-ink)]">Ambient status indicator (Moods)</td>
              <td class="p-6 text-[var(--color-mint)] font-bold bg-pink-500/5">✓ Yes</td>
              <td class="p-6 text-[var(--color-danger)] font-bold">✗ No</td>
              <td class="p-6 text-[var(--color-danger)] font-bold">✗ No</td>
            </tr>

            <!-- Row 4 -->
            <tr class="hover:bg-[var(--clay-inset)] transition-colors">
              <td class="p-6 font-semibold text-[var(--color-ink)]">Lives natively on your desktop</td>
              <td class="p-6 text-[var(--color-mint)] font-bold bg-pink-500/5">✓ Yes</td>
              <td class="p-6 text-[var(--color-danger)] font-bold">✗ No</td>
              <td class="p-6 text-[var(--color-danger)] font-bold">✗ No</td>
            </tr>

            <!-- Row 5 -->
            <tr class="hover:bg-[var(--clay-inset)] transition-colors">
              <td class="p-6 font-semibold text-[var(--color-ink)]">On-device local privacy</td>
              <td class="p-6 text-[var(--color-mint)] font-bold bg-pink-500/5">✓ Yes</td>
              <td class="p-6 text-[var(--color-danger)] font-bold">✗ No</td>
              <td class="p-6 text-[var(--color-mint)] font-bold">✓ Yes</td>
            </tr>

            <!-- Row 6 -->
            <tr class="hover:bg-[var(--clay-inset)] transition-colors">
              <td class="p-6 font-semibold text-[var(--color-ink)]">Uses your own agent keys (No markups)</td>
              <td class="p-6 text-[var(--color-mint)] font-bold bg-pink-500/5">✓ Yes</td>
              <td class="p-6 text-[var(--color-danger)] font-bold">✗ No</td>
              <td class="p-6 text-[var(--color-mint)] font-bold">✓ Yes</td>
            </tr>

          </tbody>
        </table>
      </div>
    </div>

  </div>
</section>
