---
// §8.12 — final call-to-action before the footer. Repeats the waitlist + tagline.
import WaitlistForm from "../components/WaitlistForm.astro";
---

<section class="relative overflow-hidden py-20 md:py-28 border-b border-[var(--hairline)]">
  <!-- Ambient coral + periwinkle glow behind the CTA -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute left-1/2 top-1/2 h-72 w-[36rem] max-w-[90vw] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[var(--color-coral)] opacity-[0.12] blur-3xl"></div>
    <div class="absolute left-[30%] top-[30%] h-40 w-40 rounded-full bg-[var(--color-periwinkle)] opacity-10 blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-3xl px-6 text-center flex flex-col items-center">
    <span class="eyebrow">Founder price · first 500 developers</span>

    <h2 class="mt-3 font-[family-name:var(--font-display)] text-4xl md:text-6xl font-bold leading-[0.98] tracking-tight text-[var(--color-ink)]">
      Give your AI agent<br />
      a <span class="bg-gradient-to-r from-[var(--color-coral)] to-[var(--color-peach)] bg-clip-text text-transparent">body.</span>
    </h2>

    <p class="mt-5 max-w-xl text-lg text-[var(--color-ink-dim)] leading-relaxed">
      Join the waitlist and lock in <span class="text-[var(--color-ink)] font-semibold">$19</span>
      (instead of $39) when Minnie ships. No spam — one email on launch day.
    </p>

    <!-- Waitlist -->
    <div class="mt-8 flex justify-center">
      <WaitlistForm size="lg" source="final-cta" />
    </div>

    <!-- Privacy badge -->
    <div class="mt-8 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-xs text-[var(--color-ink-softcoral)] font-semibold">
      <span>🔒 On-device voice</span>
      <span class="text-[var(--color-lilac-muted)]">•</span>
      <span>Zero extra AI cost</span>
      <span class="text-[var(--color-lilac-muted)]">•</span>
      <span>One-time — no subscription</span>
    </div>
  </div>
</section>
