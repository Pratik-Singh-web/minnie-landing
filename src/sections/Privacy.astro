---
// §8.6 — the big, reassuring privacy block. Privacy is a core Minnie promise;
// it earns its own real estate instead of being scattered across other sections.
const points = [
  {
    icon: "🎙️",
    title: "On-device voice",
    body: "Apple's local speech synthesis by default — or bring your own key. Your words are transcribed and spoken on your Mac.",
    accent: "var(--color-coral)",
  },
  {
    icon: "💻",
    title: "Your local agent CLI",
    body: "Minnie drives the agent already installed on your machine. The reasoning runs where your code lives, not on our servers.",
    accent: "var(--color-periwinkle)",
  },
  {
    icon: "🙈",
    title: "No screen capture",
    body: "She never watches your screen or records your desktop. She only sees what you ask her to work on.",
    accent: "var(--color-mint)",
  },
  {
    icon: "📡",
    title: "Zero telemetry",
    body: "No analytics, no phone-home, no usage tracking. Nothing leaves your Mac unless a tool you approved sends it.",
    accent: "var(--color-amber)",
  },
  {
    icon: "🔑",
    title: "Secrets in the Keychain",
    body: "API keys and connector tokens live only in your macOS Keychain — encrypted by the OS, never in plaintext or the cloud.",
    accent: "var(--color-coral)",
  },
  {
    icon: "🧾",
    title: "Yours, on your terms",
    body: "Delete her memory of you anytime. No account required to run the app. Local-first, always.",
    accent: "var(--color-periwinkle)",
  },
];
---

<section id="privacy" class="py-16 md:py-24 border-b border-[var(--hairline)]">
  <div class="mx-auto max-w-6xl px-6 md:px-10">
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-14">
      <span class="eyebrow">Privacy by default</span>
      <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-5xl font-bold mt-2 text-[var(--color-ink)]">
        Nothing leaves your Mac unless you ask.
      </h2>
      <p class="text-[var(--color-ink-dim)] mt-4 leading-relaxed">
        Minnie is local-first to the core. Your code, your conversations, and your
        secrets stay on your machine — no exceptions, no fine print.
      </p>

      <!-- Reassurance badge -->
      <div class="mt-6 inline-flex flex-wrap items-center justify-center gap-x-3 gap-y-1 rounded-full border border-[var(--hairline)] bg-white/[0.03] px-5 py-2.5 text-xs font-semibold text-[var(--color-ink-softcoral)]">
        <span>🔒 On-device voice</span>
        <span class="text-[var(--color-lilac-muted)]">·</span>
        <span>runs on your Mac</span>
        <span class="text-[var(--color-lilac-muted)]">·</span>
        <span>nothing leaves unless you ask</span>
      </div>
    </div>

    <!-- Privacy Grid -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        points.map((p) => (
          <div class="card p-6 hover:border-white/20 transition-colors duration-300">
            <div
              class="w-11 h-11 rounded-xl flex items-center justify-center mb-4 text-xl"
              style={`background: color-mix(in srgb, ${p.accent} 14%, transparent); border: 1px solid color-mix(in srgb, ${p.accent} 24%, transparent);`}
            >
              {p.icon}
            </div>
            <h3 class="text-base font-bold text-white mb-2">{p.title}</h3>
            <p class="text-sm text-[var(--color-ink-dim)] leading-relaxed">{p.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
