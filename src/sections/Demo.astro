---
---

<section id="demo" class="py-16 md:py-24 bg-[var(--color-bg1)] border-t border-b border-[var(--hairline)]">
  <div class="mx-auto max-w-6xl px-6 md:px-10">
    <!-- Section Header -->
    <div class="text-center max-w-2xl mx-auto mb-12">
      <span class="eyebrow">Interactive Demo</span>
      <h2 class="font-[family-name:var(--font-display)] text-3xl md:text-5xl font-bold mt-2 text-[var(--color-ink)]">
        Watch Minnie work in real-time
      </h2>
      <p class="text-[var(--color-ink-dim)] mt-4 leading-relaxed">
        Click through the interactive timeline to see Minnie diagnose a test failure, request consent, and apply the fix.
      </p>
    </div>

    <!-- Demo Wrapper -->
    <div class="grid gap-8 lg:grid-cols-12 items-stretch">
      
      <!-- Left Panel: Terminal Simulator (7 cols) -->
      <div class="lg:col-span-7 card p-6 bg-black/40 flex flex-col justify-between font-mono text-sm leading-relaxed border-white/5 shadow-2xl relative overflow-hidden">
        <!-- Terminal Header -->
        <div class="flex items-center justify-between border-b border-white/5 pb-4 mb-4">
          <div class="flex items-center gap-1.5">
            <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
          </div>
          <span class="text-xs text-[var(--color-lilac-muted)]">zsh — minnie-agent</span>
          <div class="w-12"></div>
        </div>

        <!-- Terminal Terminal Output -->
        <div id="terminal-content" class="flex-1 min-h-[300px] text-zinc-300 overflow-y-auto space-y-4">
          <!-- Step 0 State -->
          <div id="term-step-0" class="space-y-1">
            <div class="text-[var(--color-lilac-muted)]"># Terminal ready. Waiting to start...</div>
            <div class="flex items-center gap-2">
              <span class="text-[var(--color-coral)]">➜</span>
              <span class="text-white">Desktop/Minnie</span>
              <span class="animate-pulse bg-white w-1.5 h-4"></span>
            </div>
          </div>
        </div>

        <!-- Terminal Bottom Info -->
        <div class="mt-4 pt-4 border-t border-white/5 flex items-center justify-between text-xs text-[var(--color-lilac-muted)]">
          <span>Active project: Minnie</span>
          <span id="terminal-step-indicator">Step 1 of 5</span>
        </div>
      </div>

      <!-- Right Panel: Pet Interface (5 cols) -->
      <div class="lg:col-span-5 flex flex-col justify-between card p-8 border-white/5 relative bg-gradient-to-b from-white/[0.01] to-transparent">
        
        <!-- Speech cloud -->
        <div class="relative mb-6">
          <div class="bg-gradient-to-b from-white to-[#ffe3ee] text-[var(--color-ink-onlight)] rounded-2xl p-5 shadow-lg relative z-10 transition-all duration-300">
            <!-- Speech indicator dot -->
            <div class="absolute -bottom-2 right-12 w-4 h-4 bg-[#ffe3ee] transform rotate-45 z-0"></div>
            <p id="speech-bubble-text" class="text-sm font-semibold leading-relaxed">
              Hey there! Click "Start Demo" below to see how I help you code.
            </p>
          </div>
        </div>

        <!-- Pet Mood / Waveform visualization -->
        <div class="flex-1 flex flex-col items-center justify-center py-6 relative">
          <!-- Glow base -->
          <div id="mood-glow" class="absolute w-40 h-40 rounded-full bg-[var(--color-coral)] opacity-10 blur-2xl transition-all duration-500"></div>

          <!-- Pet Mascot -->
          <div class="w-36 h-36 flex items-center justify-center relative">
            <img
              src="/media/idle.png"
              alt="Minnie Mascot"
              id="demo-pet-img"
              class="max-w-full max-h-full object-contain filter drop-shadow-[0_8px_16px_rgba(255,107,157,0.2)] transition-all duration-300"
            />
          </div>

          <!-- Waveform / Action status -->
          <div class="mt-6 flex flex-col items-center gap-1">
            <span id="pet-mood-badge" class="chip">Mood: Idle</span>
            <!-- Live voice indicator bars -->
            <div id="voice-waveform" class="hidden flex items-center gap-0.5 h-4 mt-2">
              <span class="w-0.5 bg-[var(--color-coral)] rounded-full animate-[bounce_0.6s_infinite]"></span>
              <span class="w-0.5 bg-[var(--color-coral)] rounded-full animate-[bounce_0.6s_infinite_0.15s]"></span>
              <span class="w-0.5 bg-[var(--color-coral)] rounded-full animate-[bounce_0.6s_infinite_0.3s]"></span>
              <span class="w-0.5 bg-[var(--color-coral)] rounded-full animate-[bounce_0.6s_infinite_0.45s]"></span>
            </div>
          </div>
        </div>

        <!-- Interactive Control Interface -->
        <div class="mt-6 pt-6 border-t border-white/5 flex flex-col gap-3">
          <!-- Standard Next button -->
          <button
            id="demo-next-btn"
            class="btn-primary w-full justify-center cursor-pointer text-sm"
          >
            Start Demo
          </button>

          <!-- Consent Prompt Overlay (Allow / Deny) -->
          <div id="consent-options" class="hidden flex gap-2">
            <button
              id="consent-deny-btn"
              class="btn-ghost w-1/3 justify-center text-sm border-[var(--color-danger)] text-[var(--color-danger)] hover:bg-[var(--color-danger)]/5"
            >
              Deny
            </button>
            <button
              id="consent-allow-btn"
              class="btn-primary w-2/3 justify-center text-sm bg-gradient-to-r from-[var(--color-mint)] to-emerald-500 shadow-emerald-500/20"
            >
              Allow Action
            </button>
          </div>

          <!-- Reset Button -->
          <button
            id="demo-reset-btn"
            class="hidden btn-ghost w-full justify-center text-xs border-none text-[var(--color-lilac-muted)]"
          >
            Reset Demo
          </button>
        </div>

      </div>

    </div>
  </div>
</section>

<script>
  // Script steps mapping the §9 script
  const steps = [
    {
      terminal: `
        <div class="text-[var(--color-lilac-muted)]"># Prompting Minnie...</div>
        <div class="flex items-center gap-2">
          <span class="text-[var(--color-coral)]">➜</span>
          <span class="text-white">Desktop/Minnie</span>
          <span class="text-[var(--color-ink-softcoral)] font-bold">"Hey Minnie, what's wrong with my tests?"</span>
        </div>
      `,
      speech: "Let me take a look at your tests right now...",
      mood: "Thinking",
      image: "/media/thinking.png",
      glowColor: "rgba(139, 124, 255, 0.2)", // Periwinkle glow
      btnText: "Watch Minnie run tools",
      hasConsent: false
    },
    {
      terminal: `
        <div class="text-[var(--color-lilac-muted)]"># Diagnostic scan running...</div>
        <div class="flex items-center gap-2 text-yellow-400">
          <span>🔧 Bash</span>
          <span class="text-zinc-400">-> running \`pytest\`...</span>
        </div>
        <div class="text-red-400 text-xs pl-4 font-mono leading-tight">
          FAIL: test_auth.py:42 TestAuth.test_session_create<br>
          AssertionError: 'userId' not found in response dict
        </div>
      `,
      speech: "Running pytest. Oh! Looks like we have a failing assertion in your authentication test suite.",
      mood: "Walking",
      image: "/media/thinking.png", // continues diagnostic
      glowColor: "rgba(255, 194, 75, 0.15)", // Amber glow
      btnText: "Proceed to validation",
      hasConsent: false
    },
    {
      terminal: `
        <div class="text-[var(--color-lilac-muted)]"># Attempting auto-fix steps...</div>
        <div class="flex items-center gap-2 text-cyan-400">
          <span>🔧 Read</span>
          <span class="text-zinc-400">-> mock_users.py</span>
        </div>
        <div class="text-zinc-400 text-xs pl-4">
          File scan complete. Found mock user payload template missing \`userId\`.
        </div>
      `,
      speech: "I need to apply the fix to mock_users.py. I want to execute the edit. Ok?",
      mood: "Thinking",
      image: "/media/thinking.png",
      glowColor: "rgba(255, 107, 157, 0.2)",
      btnText: "",
      hasConsent: true,
      consentType: "edit"
    },
    {
      terminal: `
        <div class="text-[var(--color-lilac-muted)]"># Applying user-approved fix...</div>
        <div class="flex items-center gap-2 text-emerald-400">
          <span>🔧 Write</span>
          <span class="text-zinc-400">-> mock_users.py (modified line 42)</span>
        </div>
        <div class="text-zinc-400 text-xs pl-4">
          + "userId": "user_mock_9912",
        </div>
        <div class="flex items-center gap-2 text-yellow-400 mt-2">
          <span>🔧 Bash</span>
          <span class="text-zinc-400">-> running \`pytest\`...</span>
        </div>
      `,
      speech: "Applying the edit to line 42... Done. Now running pytest again to verify.",
      mood: "Walking",
      image: "/media/thinking.png",
      glowColor: "rgba(139, 124, 255, 0.2)",
      btnText: "See results",
      hasConsent: false
    },
    {
      terminal: `
        <div class="text-emerald-400 font-bold">✓ All 12 tests passed! (100% success rate)</div>
        <div class="text-[var(--color-lilac-muted)]"># Ready for next instruction.</div>
        <div class="flex items-center gap-2 mt-4">
          <span class="text-[var(--color-coral)]">➜</span>
          <span class="text-white">Desktop/Minnie</span>
          <span class="animate-pulse bg-white w-1.5 h-4"></span>
        </div>
      `,
      speech: "All tests are passing now! I added the missing userId parameter. We are good to go! ✨",
      mood: "Happy",
      image: "/media/idle.png",
      glowColor: "rgba(61, 220, 151, 0.25)", // Mint/Success glow
      btnText: "Demo Finished",
      hasConsent: false,
      isFinished: true
    }
  ];

  let currentStep = -1;

  // DOM Elements
  const termContent = document.getElementById('terminal-content');
  const speechBubble = document.getElementById('speech-bubble-text');
  const petImg = document.getElementById('demo-pet-img') as HTMLImageElement;
  const moodBadge = document.getElementById('pet-mood-badge');
  const moodGlow = document.getElementById('mood-glow');
  const nextBtn = document.getElementById('demo-next-btn');
  const resetBtn = document.getElementById('demo-reset-btn');
  const consentOptions = document.getElementById('consent-options');
  const allowBtn = document.getElementById('consent-allow-btn');
  const denyBtn = document.getElementById('consent-deny-btn');
  const stepIndicator = document.getElementById('terminal-step-indicator');
  const voiceWaveform = document.getElementById('voice-waveform');

  // Trigger next step
  function triggerStep() {
    currentStep++;
    if (currentStep >= steps.length) {
      currentStep = -1;
      resetDemo();
      return;
    }

    const stepData = steps[currentStep];

    // Update Terminal
    if (termContent) {
      termContent.innerHTML += stepData.terminal;
      termContent.scrollTop = termContent.scrollHeight;
    }

    // Update Speech & wave animation
    if (speechBubble) {
      speechBubble.textContent = stepData.speech;
    }

    // Voice activation animation
    if (voiceWaveform) {
      voiceWaveform.classList.remove('hidden');
      setTimeout(() => {
        voiceWaveform.classList.add('hidden');
      }, 2000);
    }

    // Update Mascot image & mood
    if (petImg) petImg.src = stepData.image;
    if (moodBadge) moodBadge.textContent = `Mood: ${stepData.mood}`;
    if (moodGlow) moodGlow.style.backgroundColor = stepData.glowColor;

    // Update Indicators
    if (stepIndicator) stepIndicator.textContent = `Step ${currentStep + 1} of ${steps.length}`;

    // Manage Buttons / Interactivity
    if (stepData.hasConsent) {
      if (nextBtn) nextBtn.classList.add('hidden');
      if (consentOptions) consentOptions.classList.remove('hidden');
    } else {
      if (nextBtn) {
        nextBtn.classList.remove('hidden');
        nextBtn.textContent = stepData.btnText;
      }
      if (consentOptions) consentOptions.classList.add('hidden');
    }

    if (resetBtn) resetBtn.classList.remove('hidden');
    
    if (stepData.isFinished && nextBtn) {
      nextBtn.textContent = "Restart Demo";
    }
  }

  function resetDemo() {
    currentStep = -1;
    if (termContent) {
      termContent.innerHTML = `
        <div id="term-step-0" class="space-y-1">
          <div class="text-[var(--color-lilac-muted)]"># Terminal ready. Waiting to start...</div>
          <div class="flex items-center gap-2">
            <span class="text-[var(--color-coral)]">➜</span>
            <span class="text-white">Desktop/Minnie</span>
            <span class="animate-pulse bg-white w-1.5 h-4"></span>
          </div>
        </div>
      `;
    }
    if (speechBubble) speechBubble.textContent = 'Hey there! Click "Start Demo" below to see how I help you code.';
    if (petImg) petImg.src = '/media/idle.png';
    if (moodBadge) moodBadge.textContent = 'Mood: Idle';
    if (moodGlow) moodGlow.style.backgroundColor = 'rgba(255, 107, 157, 0.1)';
    if (nextBtn) {
      nextBtn.classList.remove('hidden');
      nextBtn.textContent = 'Start Demo';
    }
    if (consentOptions) consentOptions.classList.add('hidden');
    if (resetBtn) resetBtn.classList.add('hidden');
    if (stepIndicator) stepIndicator.textContent = 'Step 1 of 5';
  }

  // Hook event listeners
  if (nextBtn) nextBtn.addEventListener('click', triggerStep);
  if (resetBtn) resetBtn.addEventListener('click', resetDemo);
  
  if (allowBtn) {
    allowBtn.addEventListener('click', () => {
      triggerStep();
    });
  }

  if (denyBtn) {
    denyBtn.addEventListener('click', () => {
      if (speechBubble) speechBubble.textContent = "No problem! I skipped that edit. Trust stays intact. Click reset to try again.";
      if (petImg) petImg.src = '/media/idle.png';
      if (moodBadge) moodBadge.textContent = 'Mood: Sad';
      if (moodGlow) moodGlow.style.backgroundColor = 'rgba(255, 107, 107, 0.15)'; // Red glow for skip
      if (consentOptions) consentOptions.classList.add('hidden');
    });
  }
</script>
